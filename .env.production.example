# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES - ZILACART
# =============================================================================
# ⚠️ CRITICAL: Never commit real credentials to version control!
# Copy this file to .env.local and fill in with actual values

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Public Firebase config (safe to expose - prefixed with NEXT_PUBLIC_)
# Get from: https://console.firebase.google.com/ → Project Settings → Web App Config
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin SDK (server-side only - KEEP PRIVATE)
FIREBASE_ADMIN_SDK_KEY=path/to/serviceAccountKey.json

# =============================================================================
# GENKIT AI / GOOGLE API
# =============================================================================
# Google AI API key for Gemini and Genkit flows
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# PAYPAL INTEGRATION
# =============================================================================
# API Credentials from: https://developer.paypal.com/dashboard/
# Mode: 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_client_id_here
PAYPAL_CLIENT_SECRET=your_client_secret_here
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_public_client_id_here

# Webhook ID from PayPal Dashboard → Webhooks
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# =============================================================================
# STRIPE INTEGRATION (Optional)
# =============================================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP Server settings for order confirmations and notifications
# Choose ONE email provider below and configure it

# Option 1: Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=ZilaCart

# Option 2: SendGrid (recommended for production)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_api_key_here
# SMTP_FROM_EMAIL=noreply@zilacart.com
# SMTP_FROM_NAME=ZilaCart

# Option 3: Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your_mailgun_password
# SMTP_FROM_EMAIL=noreply@your-domain

# Option 4: AWS SES
# SMTP_HOST=email-smtp.YOUR_REGION.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your_ses_smtp_username
# SMTP_PASS=your_ses_smtp_password
# SMTP_FROM_EMAIL=noreply@zilacart.com
# SMTP_FROM_NAME=ZilaCart

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Base URL for email links and webhooks
NEXT_PUBLIC_BASE_URL=https://mart-blond.vercel.app

# Node environment
NODE_ENV=production

# =============================================================================
# OPTIONAL: M-PESA INTEGRATION
# =============================================================================
# M-Pesa credentials (if applicable for Kenya market)
# Get from: Safaricom Daraja API documentation
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://mart-blond.vercel.app/api/webhooks/mpesa

# =============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# =============================================================================
# Sentry (error tracking) - optional but recommended
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id

# =============================================================================
# SECURITY NOTES
# =============================================================================
# ✅ DO:
# - Keep this file and all credentials PRIVATE
# - Use strong, unique passwords/keys for each service
# - Rotate credentials regularly
# - Never commit .env files to git
# - Use .env.local for local development
# - Add .env to .gitignore

# ❌ DON'T:
# - Commit real credentials to version control
# - Share credentials via email or chat
# - Use simple passwords
# - Reuse credentials across services
# - Store credentials in comments
# - Use production credentials during development
